# Copy to .env and adjust. Loaded by Makefile targets and the binaries.
DATABASE_URL=postgres://charging:charging@localhost:5433/charging?sslmode=disable

# OCPI source tokens (request free key: myevplatform@energyvision.be)
ENERGYVISION_TOKEN=

# API server
API_ADDR=:8080

# Reference vehicle for the comparable session prices (defaults: mid-size EV)
VEHICLE_USABLE_KWH=60
VEHICLE_CONSUMPTION_KWH100=18

# Operational tuning
AVAILABILITY_STALE_AFTER=15m   # availability older than this = not "available"
PRICE_STALE_AFTER=48h          # readiness: max age of last successful price ingest
METRICS_ADDR=:9090             # ingest process Prometheus /metrics
