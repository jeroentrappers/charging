# Copy to .env and adjust. Loaded by Makefile targets and the binaries.
DATABASE_URL=postgres://charging:charging@localhost:5433/charging?sslmode=disable

# OCPI source tokens (request free key: myevplatform@energyvision.be)
ENERGYVISION_TOKEN=

# Monta Public API credentials, "clientId:clientSecret" (for the 'monta' source)
MONTA_CREDS=

# API server
API_ADDR=:8080
CORS_ORIGINS=*                 # comma-separated allowed origins for browser clients
ADMIN_TOKEN=                   # bearer token for /admin/*; empty = admin disabled

# OCPI eMSP (acting as a data consumer). PUBLIC_URL is the externally reachable
# API base — used to advertise our absolute /ocpi endpoints in the handshake.
PUBLIC_URL=                    # e.g. https://charging.appmire.be/api
OCPI_COUNTRY=BE
OCPI_PARTY_ID=APM
OCPI_PARTY_NAME=Appmire Charging

# Reference vehicle for the comparable session prices (defaults: mid-size EV)
VEHICLE_USABLE_KWH=60
VEHICLE_CONSUMPTION_KWH100=18

# Operational tuning
AVAILABILITY_STALE_AFTER=15m   # availability older than this = not "available"
PRICE_STALE_AFTER=48h          # readiness: max age of last successful price ingest
METRICS_ADDR=:9090             # ingest process Prometheus /metrics

# Open bulk dataset export (static dumps served at /export). Empty dir disables.
EXPORT_DIR=./export
EXPORT_FULL_EVERY=5m           # full NDJSON/GeoJSON/OCPI snapshot cadence
EXPORT_AVAIL_EVERY=1m          # availability-delta cadence

# Corridor search (GET /chargers/along-route). Base URL of a self-hosted
# osrm-routed server; empty disables it. With docker-compose.osrm.yml this is
# set automatically to http://osrm:5000 (run ./scripts/osrm-prep.sh once first).
OSRM_URL=
# Which prepared OSRM graph the osrm service loads (/data/<OSRM_GRAPH>.osrm),
# and what osrm-prep.sh builds. Dev default belgium-latest; for cross-country
# routing run e.g. OSRM_GRAPH=eu-west OSRM_REGIONS="europe/belgium europe/netherlands
# europe/luxembourg europe/germany europe/france" ./scripts/osrm-prep.sh
OSRM_GRAPH=belgium-latest

# DE Mobilithek (AFIR DATEX II — live availability + ad-hoc price). Mutual-TLS
# org client certificate (PEM paths inside the container; mount them in). Then
# add one source per CPO/aggregator offering with the two subscription pull URLs:
#   chargingctl sources add de-<cpo> --type mobilithek \
#     --url "<static-subscription-url>|<status-subscription-url>"
# See docs/mobilithek.md. Leave empty to disable.
MOBILITHEK_CERT_FILE=
MOBILITHEK_KEY_FILE=
MOBILITHEK_CA_FILE=
# Mobilithek consumer-push (webhook): the broker POSTs AFIR DATEX II JSON to
# POST /mobilithek/push?token=<this>. Register that tokenized URL on Mobilithek.
# Empty disables the receiver. Optional capture dir saves raw payloads.
MOBILITHEK_PUSH_TOKEN=
MOBILITHEK_CAPTURE_DIR=
