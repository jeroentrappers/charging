# Managed by Ansible. Reverse-proxies {{ charging_domain }} to the loopback
# docker stack: PWA on :{{ web_loopback_port }}, API on :{{ api_loopback_port }}
# (same-origin under /api/, prefix stripped). Mirrors appmire4-web.
{% if have_cert | default(false) %}
server {
    server_name {{ charging_domain }};

    location /api/ {
        proxy_pass http://127.0.0.1:{{ api_loopback_port }}/;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }

    location / {
        proxy_pass http://127.0.0.1:{{ web_loopback_port }};
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    listen [::]:443 ssl;
    listen 443 ssl;
    ssl_certificate /etc/letsencrypt/live/{{ charging_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ charging_domain }}/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

server {
    if ($host = {{ charging_domain }}) {
        return 301 https://$host$request_uri;
    }
    server_name {{ charging_domain }};
    listen 80;
    listen [::]:80;
    return 404;
}
{% else %}
# HTTP-only until certbot issues a cert (first deploy). Keeps the site
# reachable and lets `certbot --nginx` validate the domain.
server {
    server_name {{ charging_domain }};
    listen 80;
    listen [::]:80;

    location /api/ {
        proxy_pass http://127.0.0.1:{{ api_loopback_port }}/;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }

    location / {
        proxy_pass http://127.0.0.1:{{ web_loopback_port }};
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
{% endif %}
