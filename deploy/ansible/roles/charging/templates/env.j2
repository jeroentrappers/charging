# Managed by Ansible (deploy/ansible/group_vars/charging/vault.yml).
# Do not edit on the box — changes are overwritten on the next deploy.
{% for k, v in charging_env.items() %}
{{ k }}={{ v }}
{% endfor %}
# OSRM graph name (non-secret; selects /data/<graph>.osrm in the osrm service).
OSRM_GRAPH={{ osrm_graph }}
{% if mobilithek_capture | default(false) %}
# Debug: persist every received Mobilithek push to this (bind-mounted) dir.
MOBILITHEK_CAPTURE_DIR=/capture
{% endif %}
